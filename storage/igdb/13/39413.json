{"id":39413,"cover":{"id":395452,"image_id":"co8h4s","url":"//images.igdb.com/igdb/image/upload/t_thumb/co8h4s.jpg"},"first_release_date":725846400,"genres":[{"id":4,"name":"Fighting"}],"involved_companies":[{"id":272721,"company":{"id":112,"name":"Sega"},"developer":false,"publisher":true},{"id":272720,"company":{"id":2327,"name":"Sega AM3"},"developer":true,"publisher":false}],"name":"Dark Edge","release_dates":[{"id":447341,"date":725846400,"human":"Jan 1993","platform":{"id":52,"name":"Arcade"},"release_region":{"id":5,"region":"japan"}}],"screenshots":[{"id":1347856,"image_id":"scsw0g","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsw0g.jpg"},{"id":1347857,"image_id":"scsw0h","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsw0h.jpg"},{"id":1347858,"image_id":"scsw0i","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsw0i.jpg"},{"id":1347859,"image_id":"scsw0j","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsw0j.jpg"},{"id":1349651,"image_id":"scsxeb","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsxeb.jpg"},{"id":1349652,"image_id":"scsxec","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsxec.jpg"},{"id":1349653,"image_id":"scsxed","url":"//images.igdb.com/igdb/image/upload/t_thumb/scsxed.jpg"}],"similar_games":[89550,5867,14704,14362,36732,55038,36911,25311,105269,54844],"slug":"dark-edge","summary":"Dark Edge is a 1992 fighting game by Sega for the Sega System 32. It uses sprite scaling to simulate a 3D playfield, meaning it predates Virtua Fighter as a 3D fighter by about a year (though the 3D in Virtua Fighter isn't simulated, but rather true rendered 3D graphics). You can play as either warriors or monsters, but otherwise this is a typical fighting game with a dedicated jump button (as Up moves back). Although the title screen reads \"1992\", the arcade game was first sold in early 1993.","url":"https://www.igdb.com/games/dark-edge","videos":[{"id":117997,"video_id":"zBXZ9f-dCMM"}],"websites":[{"id":524082,"url":"https://sega