":{"id":2,"region":"north_america"}},{"id":754548,"date":610070400,"human":"May 02, 1989","platform":{"id":14,"name":"Mac"},"release_region":{"id":2,"region":"north_america"}},{"id":754547,"date":570758400,"human":"Feb 02, 1988","platform":{"id":13,"name":"DOS"},"release_region":{"id":2,"region":"north_america"}},{"id":754535,"date":536371200,"human":"1986","platform":{"id":25,"name":"Amstrad CPC"},"release_region":{"id":1,"region":"europe"}},{"id":754536,"date":576201600,"human":"Apr 05, 1988","platform":{"id":75,"name":"Apple II"},"release_region":{"id":2,"region":"north_america"}},{"id":754537,"date":573177600,"human":"Mar 01, 1988","platform":{"id":115,"name":"Apple IIGS"},"release_region":{"id":2,"region":"north_america"}},{"id":754541,"date":504835200,"human":"1985","platform":{"id":65,"name":"Atari 8-bit"},"release_region":{"id":1,"region":"europe"}},{"id":754543,"date":567907200,"human":"1987","platform":{"id":63,"name":"Atari ST/STE"},"release_region":{"id":1,"region":"europe"}},{"id":754544,"date":560044800,"human":"Oct 01, 1987","platform":{"id":63,"name":"Atari ST/STE"},"release_region":{"id":2,"region":"north_america"}},{"id":754545,"date":536371200,"human":"1986","platform":{"id":15,"name":"Commodore C64/128/MAX"},"release_region":{"id":1,"region":"europe"}},{"id":754546,"date":557452800,"human":"Sep 01, 1987","platform":{"id":15,"name":"Commodore C64/128/MAX"},"release_region":{"id":2,"region":"north_america"}},{"id":754550,"date":599529600,"human":"1988","platform":{"id":27,"name":"MSX"},"release_region":{"id":2,"region":"north_america"}},{"id":754551,"date":662601600,"human":"1990","platform":{"id":64,"name":"Sega Master System/Mark III"},"release_region":{"id":1,"region":"europe"}},{"id":754552,"date":536371200,"human":"1986","platform":{"id":26,"name":"ZX Spectrum"},"release_region":{"id":1,"region":"europe"}}],"screenshots":[{"id":356232,"image_id":"sc7mvc","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc7mvc.jpg"},{"id":356233,"image_id":"sc7mvd","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc7mvd.jpg"},{"id":356231,"image_id":"sc7mvb","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc7mvb.jpg"},{"id":1755390,"image_id":"sc11mgu","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc11mgu.jpg"},{"id":1755391,"image_id":"sc11mgv","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc11mgv.jpg"},{"id":1755389,"image_id":"sc11mgt","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc11mgt.jpg"}],"similar_games":[9938,15127,660,11646,2365,14394,7056,9834,54775,19133],"slug":"gauntlet","summary":"The players, up to four at once in the arcade version, select among four playable fantasy-based characters; Thor the Warrior, Merlin the Wizard, Thyra the Valkyrie, or Questor the Elf. Each character has his or her own unique strength and weaknesses. For example, the Warrior is strongest in hand-to-hand combat, the Wizard has the most powerful magic, the Valkyrie has the best armour and the Elf is the fastest in movement.\n\nUpon selecting a playable character, the gameplay is set within a series of top-down, third-person perspective mazes where the object is to find and touch the designated exit in every level. An assortment of special items can be located in each level that increase player's character's health, unlock doors, gain more points and magical potions that can destroy all of the enemies on screen.\nThe enemies are an assortment of fantasy-based monsters, including ghosts, grunts, demons, lobbers, sorcerers and thieves. Each enters the level through specific generators, which can be destroyed. While there are no bosses in the game, the most dangerous enemy is \"Death\", who can not only drain a character's health, but is difficult to destroy.\nAs the game progresses, higher levels of skill are needed to reach the exit, with success often depending on the willingness of the players to cooperate by sharing food and luring monsters into places where they can be engaged and slaughtered more conveniently. While contact with enemies reduces the player's health, it also slowly drains on its own, thus creating a time limit. When a character's health reaches zero, that character dies. The character can be revived in place with full health by spending a game credit (i.e. inserting a coin) within a certain short time window after it died. This allows even the least proficient players to keep playing indefinitely, if they are willing to keep inserting coins.","total_rating":73.67322356937937,"total_rating_count":48,"url":"https://www.igdb.com/games/gauntlet","videos":[{"id":2441,"video_id":"94gY2QiyDVg"}],"websites":[{"id":167925,"url":"https://en.wikipedia.org/wiki/Gauntlet_(1985_video_game)","type":{"id":3,"type":"Wikipedia"}},{"id":342504,"url":"https://www.twitch.tv/directory/game/Gauntlet","type":{"id":6,"type":"Twitch"}}]}