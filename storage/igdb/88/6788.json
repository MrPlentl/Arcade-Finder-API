"id":52,"name":"Arcade"},"release_region":{"id":5,"region":"japan"}},{"id":843450,"date":883526400,"human":"1997","platform":{"id":6,"name":"PC (Microsoft Windows)"},"release_region":{"id":2,"region":"north_america"}}],"screenshots":[{"id":215789,"image_id":"p6kb6fjrzclxzk63op4c","url":"//images.igdb.com/igdb/image/upload/t_thumb/p6kb6fjrzclxzk63op4c.jpg"},{"id":215788,"image_id":"mzsu0mmu0v20jcehssvv","url":"//images.igdb.com/igdb/image/upload/t_thumb/mzsu0mmu0v20jcehssvv.jpg"},{"id":432489,"image_id":"sc99pl","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pl.jpg"},{"id":432490,"image_id":"sc99pm","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pm.jpg"},{"id":432491,"image_id":"sc99pn","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pn.jpg"},{"id":432492,"image_id":"sc99po","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99po.jpg"},{"id":432493,"image_id":"sc99pp","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pp.jpg"},{"id":432494,"image_id":"sc99pq","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pq.jpg"},{"id":432495,"image_id":"sc99pr","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pr.jpg"},{"id":432496,"image_id":"sc99ps","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99ps.jpg"},{"id":432497,"image_id":"sc99pt","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pt.jpg"},{"id":432498,"image_id":"sc99pu","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc99pu.jpg"}],"similar_games":[22799,10212,77488,113114,10213,55038,10209,105269,43367,111846],"slug":"darius-gaiden","summary":"Darius Gaiden is a two-dimensional shoot'em up. The player controls a space ship named the Silver Hawk and must guide it through scrolling stages, destroying enemies and avoiding obstacles along the way. The ship is armed with forward-firing missiles, aerial bombs and a protective force-field, all of which can be upgraded by various power-ups that are dropped by specially-colored enemies when they are destroyed by the player. New to the Silver Hawk's arsenal in Darius Gaiden is the 'black hole bomb.' When fired, the black hole bomb will create a large vortex in the center of the screen, which sucks in enemies and projectiles on the screen for a short moment, until it explodes into a powerful ball of lightning that inflicts massive damage onto every enemy on the screen.\n\nAnother feature introduced Darius Gaiden is the ability to capture minibosses, who appear in every stage. Each miniboss has a small, circular ball placed on them that, after receiving enough damage, will detach and float away, causing the miniboss to turn idle. If the player collects the ball, the miniboss will follow and aid the player. After a brief period of time, or the player loses a life, the miniboss will explode.\n\nA few months following release, update to the arcade version was later released entitled \"Darius Gaiden Extra Edition\". This version of arcade game contains rearranged levels, as well as automatically-enabled auto fire, two extra weapon power levels (bigger wave shot and a bigger red wave shot as well) and an all-stage mode which can be accessed by starting the game in 2P side.","total_rating":74.33100335827626,"total_rating_count":13,"url":"https://www.igdb.com/games/darius-gaiden","videos":[{"id":2424,"video_id":"NzU6anX8IQE"}],"websites":[{"id":178032,"url":"https://twitter.com/TaitoCorp","type":{"id":5,"type":"Twitter"}},{"id":178030,"url":"https://youtube.com/TAITO.Eng","type":{"id":9,"type":"YouTube"}},{"id":1678,"url":"http://en.wikipedia.org/wiki/Darius_Gaiden","type":{"id":2,"type":"Community Wiki"}},{"id":178033,"url":"https://www.instagram.com/taitostation","type":{"id":8,"type":"Instagram"}},{"id":178031,"url":"https://www.facebook.com/TAITO.Eng","type":{"id":4,"type":"Facebook"}},{"id":178029,"url":"https://darius.jp/","type":{"id":1,"type":"Official Website"}},{"id":343098,"url":"https://www.twitch.tv/directory/game/Darius%20Gaiden","type":{"id":6,"type":"Twitch"}},{"id":178034,"url":