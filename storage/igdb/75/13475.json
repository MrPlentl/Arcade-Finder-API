":"Sega Saturn"},"release_region":{"id":2,"region":"north_america"}},{"id":768524,"date":821491200,"human":"Jan 13, 1996","platform":{"id":7,"name":"PlayStation"},"release_region":{"id":5,"region":"japan"}},{"id":768527,"date":1319932800,"human":"Oct 30, 2011","platform":{"id":38,"name":"PlayStation Portable"},"release_region":{"id":2,"region":"north_america"}},{"id":768526,"date":1198627200,"human":"Dec 26, 2007","platform":{"id":9,"name":"PlayStation 3"},"release_region":{"id":2,"region":"north_america"}},{"id":768529,"date":813715200,"human":"Oct 15, 1995","platform":{"id":58,"name":"Super Famicom"},"release_region":{"id":5,"region":"japan"}},{"id":768528,"date":1198627200,"human":"Dec 26, 2007","platform":{"id":38,"name":"PlayStation Portable"},"release_region":{"id":5,"region":"japan"}},{"id":311311,"date":820368000,"human":"Q4 1995","platform":{"id":52,"name":"Arcade"},"release_region":{"id":2,"region":"north_america"}},{"id":311310,"date":820368000,"human":"Q4 1995","platform":{"id":52,"name":"Arcade"},"release_region":{"id":5,"region":"japan"}}],"screenshots":[{"id":630824,"image_id":"scdiqw","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdiqw.jpg"},{"id":630825,"image_id":"scdiqx","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdiqx.jpg"},{"id":630826,"image_id":"scdiqy","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdiqy.jpg"},{"id":630827,"image_id":"scdiqz","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdiqz.jpg"},{"id":630828,"image_id":"scdir0","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir0.jpg"},{"id":630829,"image_id":"scdir1","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir1.jpg"},{"id":630830,"image_id":"scdir2","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir2.jpg"},{"id":630832,"image_id":"scdir4","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir4.jpg"},{"id":630831,"image_id":"scdir3","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir3.jpg"},{"id":630833,"image_id":"scdir5","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir5.jpg"},{"id":630834,"image_id":"scdir6","url":"//images.igdb.com/igdb/image/upload/t_thumb/scdir6.jpg"}],"similar_games":[71332,111187,17130,1447,19376,17111,51945,3700,4260,49559],"slug":"chain-reaction","summary":"The arcade game \"Magical Drop\" received an updated version named \"Magical Drop Plus 1!\" that features aesthetic improvements and also introduces a \"Solo Play\" mode. Magical Drop Plus 1! was released in North America and Europe as \"Chain Reaction\"; in this version, the puzzle pieces are changed from spherical Drops to various items (such as food or celestial bodies) and the character-unique voice acting is replaced by a single male narrator.\n\nAll versions of the original arcade game were developed for Data East's \"MLC\" arcade hardware.\n\nThe game includes two game modes: the one-player score-based Solo Play (where additional lines of tiles regularly drop from the top of the screen) and two-player competitive Battle Mode (where the second player can be human or CPU opponents). Similar to Tetris Attack, players can make \"chain reactions\" by quickly creating near-simultaneous matches to either boost their score (in Solo Play) or fill up more of their opponent's playfield (in Battle Mode).\n\nMagical Drop was ported to the Super Famicom, which includes a puzzle mode that challenges players to solve preset puzzles given a limited number of possible moves. The game was re-imagined for the Sony PlayStation and Sega Saturn with different, pre-rendered characters. The Sega Saturn port was going to be released in America by Koei, and appeared at E3 1997, however the American release was cancelled. Finally, a port of the game is part of Magical Drop III + Wonderful; this includes the PAL version of III + Wonderful, which retains the Magical Drop Plus 1! name as opposed to using Chain Reaction.","url":"https://www.igdb.com/games/chain-reaction","videos":[{"id":54773,"video_id":"DAEx55q8h-8"},{"id":54771,"video_id":"sYWNFrXdl8E"},{"id":54772,"video_id":"4H1-sFhWUXs"}],"websites":[{"id":830009,"url":"https://en.wikipedia.org/wiki/Magical_Drop_(video_game)","type":{"id":3,"type":"Wikipedia"}},{"id":225186,"url":"https://mdcd.fandom.com/wiki/Magical_Drop","type":{"id":2,"type":"Community Wiki"}},{"id":356817,"url":"https://www.twitch.tv/directory/game/Chain%20Reaction","type":{"id":6,"type":"Twitch"}}]}