f them.","total_rating":58.21579329242262,"total_rating_count":22,"url":"https://www.igdb.com/games/tempest","websites":[{"id":184118,"url":"https://en.wikipedia.org/wiki/Tempest_(video_game)","type":{"id":3,"type":"Wikipedia"}}]}