ase_region":{"id":5,"region":"japan"}}],"screenshots":[{"id":26794,"image_id":"x7xmp7funlbjqe3dwlmi","url":"//images.igdb.com/igdb/image/upload/t_thumb/x7xmp7funlbjqe3dwlmi.jpg"}],"similar_games":[112078,37419,27378,87728,43367,36553,103302,25311,35994,118871],"slug":"after-burner-climax","summary":"Sega's airborne combat series soars back into arcades with more than 20 stages of high-flying action in After Burner Climax. Players can climb into the cockpit of an F-14 Super Tomcat, an F-15E Strike Eagle, or an F/A-19E Super Hornet and speed through the skies, dodging planes, rockets, and bullets while try to target and take down as many enemies as possible. A branching storyline and time limits force gamers into split-second decisions, but once the \"Climax Gauge\" is full, time slows down momentarily to let pilots unleash a screen-clearing fusillade of bullets.\n\nThe game was delisted on PlayStation Network and Xbox Live Arcade in December 2014. The mobile versions followed suit, being delisted in May 2015. In April 2019, the mobile versions were relisted as free games containing ads as apart of the Sega Forever line, before being delisted once again at an unknown date.","total_rating":76.862368986749,"total_rating_count":9,"url":"https://www.igdb.com/games/after-burner-climax","videos":[{"id":27426,"video_id":"YvjNVom4EnA"}],"websites":[{"id":107242,"url":"https://www.sega.com/games/after-burner-climax%E2%84%A2","type":{"id":1,"type":"Official Website"}},{"id":107243,"url":"https://en.wikipedia.org/wiki/After_Burner_Climax","type":{"id":3,"type":"Wikipedia"}},{"id":349637,"url":"https://www.twitch.tv/directory/game/After%20Burner%20Climax","type":{"id":6,"type":"Twitch"}}]}