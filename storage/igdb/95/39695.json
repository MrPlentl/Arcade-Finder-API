v 20, 1990","platform":{"id":29,"name":"Sega Mega Drive/Genesis"},"release_region":{"id":5,"region":"japan"}},{"id":238254,"date":620611200,"human":"Sep 01, 1989","platform":{"id":52,"name":"Arcade"},"release_region":{"id":5,"region":"japan"}},{"id":238258,"date":1262217600,"human":"2009","platform":{"id":5,"name":"Wii"},"release_region":{"id":8,"region":"worldwide"}},{"id":437347,"date":709948800,"human":"Jul 1992","platform":{"id":64,"name":"Sega Master System/Mark III"},"release_region":{"id":10,"region":"brazil"}},{"id":505972,"date":687398400,"human":"Oct 14, 1991","platform":{"id":29,"name":"Sega Mega Drive/Genesis"},"release_region":{"id":10,"region":"brazil"}},{"id":238259,"date":631065600,"human":"Q4 1989","platform":{"id":52,"name":"Arcade"},"release_region":{"id":2,"region":"north_america"}}],"screenshots":[{"id":389830,"image_id":"sc8csm","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc8csm.jpg"},{"id":389831,"image_id":"sc8csn","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc8csn.jpg"},{"id":431757,"image_id":"sc9959","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc9959.jpg"},{"id":431758,"image_id":"sc995a","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc995a.jpg"},{"id":431759,"image_id":"sc995b","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc995b.jpg"},{"id":431760,"image_id":"sc995c","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc995c.jpg"},{"id":431761,"image_id":"sc995d","url":"//images.igdb.com/igdb/image/upload/t_thumb/sc995d.jpg"}],"similar_games":[22799,10212,10213,10209,256456,130707,64075,46770,40047,43367],"slug":"darius-ii","summary":"Darius II is a 1989 arcade video game developed by Taito. It is the direct sequel to the 1987 Darius. It was later released as Sagaia in Japan in 1991 for the Game Boy as well as non-Japanese ports. A remake was released for the PC Engine Super CD-ROM as Super Darius II in 1993.\n\nA Mega Drive conversion was released in Japan in 1990; it was later released for the Genesis in the United States and Brazil in 1991, where it was renamed Sagaia. Changes include a boss rush mode (via a code) and various modifications to levels and mechanics, such as the boss Steel Spine being moved to another level and the boss Killer Higia being replaced with a similar creation called Nehonojia. This conversion does not support two players, so the ability to choose between Proco Jr. and Tiat Young was added; Proco plays like normal, while Tiat starts every life off with one power level to every weapon.\n\nA Master System conversion, developed by Natsume, was released in Europe and Brazil in 1992, also titled Sagaia. It is somewhat based on the Mega Drive port, and while Tiat Young and her abilities are still present (though even more limited), many zones (and thus bosses) have been completely removed.\n\nThe Super CD-ROM version features an entirely new set of bosses, major changes to levels, and a fully arranged soundtrack including new songs.","total_rating":69.9701659518926,"total_rating_count":6,"url":"https://www.igdb.com/games/darius-ii","videos":[{"id":47873,"video_id":"L6yN6rRheJI"}],"websites":[{"id":138262,"url":"https://darius.fandom.com/wiki/Darius_II","type":{"id":2,"type":"Community Wiki"}},{"id":177447,"url":"https://en.wikipedia.org/wiki/Darius_II_(video_game)","type":{"id":3,"type":"Wikipedia"}},{"id":177443,"url":"https://www.youtube.com/user/taitochannel","type":{"id":9,"type":"YouTube"}},{"id":336086,"url":"https://www.twitch.tv/directory/game/Sagaia","type":{"id":6,"type":"Twitch"}},{"id":177444,"url":"https://www.facebook.com/TAITO.Eng","type":{"id":4,"type":"Facebook"}},{"id":177445,"url":"https://twitter.com/TaitoCorp","type":{"id":5,"type":"Twitter"}},{"id":177442,"url":"https://www.taito.co.jp/","type":{"id":1,"type":"Official Website"}},{"id":177446,"url":"https://www.instagram.com/taitostation","type":{"id":8,"type":"Instagram"}}]}